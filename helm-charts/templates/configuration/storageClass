{{- if eq .Values.persistVolume true }}
kind: StorageClass
apiVersion: storage.k8s.io/v1
metadata:
  name: {{ .Values.appName }}-str
  namespace: "{{ .Values.appNamespace }}-ns"
provisioner: kubernetes.io/azure-file
mountOptions:
  - dir_mode=0777
  - file_mode=0777
  - uid=0
  - gid=0
  - mfsymlinks
  - cache=strict
  - actimeo=30
parameters:
  skuName: Standard_LRS
  storageAccount: {{ .Values.persistVolumedetails.storageAccount }}
  resourceGroup: {{ .Values.persistVolumedetails.resourceGroup }}
  shareName: {{ .Values.image.repository }}sharename
{{- end }}
